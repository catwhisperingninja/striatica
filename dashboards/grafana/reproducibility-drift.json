{
  "dashboard": {
    "id": null,
    "uid": "striatica-reproducibility",
    "title": "Striatica — Reproducibility & Drift Monitor",
    "description": "Catch UMAP drift the instant it happens. Track output hashes, dependency versions, platform, and position deviation across pipeline runs.",
    "tags": ["striatica", "reproducibility", "drift", "umap"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "model_id",
          "type": "query",
          "datasource": "${DS_PROMETHEUS}",
          "query": "label_values(striatica_pipeline_run_info, model_id)",
          "refresh": 2,
          "multi": true,
          "includeAll": true
        },
        {
          "name": "run_id",
          "type": "query",
          "datasource": "${DS_PROMETHEUS}",
          "query": "label_values(striatica_pipeline_run_info{model_id=~\"$model_id\"}, run_id)",
          "refresh": 2,
          "multi": false,
          "includeAll": false,
          "sort": 2
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "type": "dashboard"
        }
      ]
    },
    "panels": [
      {
        "title": "🚨 DRIFT STATUS",
        "description": "Red = position drift detected between this run and reference dataset. Green = positions match within tolerance.",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "striatica_position_drift_max{model_id=~\"$model_id\", run_id=\"$run_id\"}",
            "legendFormat": "Max Drift"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 6,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.001, "color": "yellow"},
                {"value": 0.01, "color": "red"}
              ]
            },
            "mappings": [
              {
                "type": "range",
                "options": {
                  "from": 0,
                  "to": 0.001,
                  "result": {"text": "CLEAN", "color": "green"}
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 0.001,
                  "to": 0.01,
                  "result": {"text": "WARN — minor drift", "color": "yellow"}
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 0.01,
                  "to": 999999,
                  "result": {"text": "DRIFT DETECTED", "color": "red"}
                }
              }
            ]
          }
        }
      },
      {
        "title": "Output Hash",
        "description": "SHA-256 of the output JSON. Same input + same deps + same platform = same hash.",
        "type": "stat",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "{{output_sha256}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      },
      {
        "title": "Platform",
        "description": "Architecture the pipeline ran on. Cross-platform = drift risk.",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "{{platform_arch}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      },
      {
        "title": "UMAP Random State",
        "description": "Should always be 42. If it's not, something's wrong.",
        "type": "stat",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "striatica_umap_random_state{run_id=\"$run_id\"}",
            "legendFormat": "random_state"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 42, "color": "green"},
                {"value": 43, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "title": "Feature Count",
        "type": "stat",
        "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_feature_count{run_id=\"$run_id\"}",
            "legendFormat": "features"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          }
        }
      },
      {
        "title": "",
        "type": "row",
        "gridPos": {"x": 0, "y": 4, "w": 24, "h": 1},
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Dependency Versions — UMAP Reproducibility Chain",
        "description": "These exact versions produced the Feb 27 2026 positions. Any change here means drift.",
        "type": "table",
        "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "striatica_dep_version_info{run_id=\"$run_id\", package=~\"numpy|scipy|scikit-learn|umap-learn|hdbscan|numba|pynndescent\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "run_id": true,
                "model_id": true,
                "job": true,
                "instance": true,
                "Value": true
              },
              "renameByName": {
                "package": "Package",
                "version": "Installed Version",
                "pinned_version": "Expected Pin"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Installed Version"},
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "type": "color-background",
                    "mode": "gradient"
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "title": "Dependency Versions — Other Packages",
        "description": "ML and utility packages. Safe to update, but tracked for audit.",
        "type": "table",
        "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "striatica_dep_version_info{run_id=\"$run_id\", package!~\"numpy|scipy|scikit-learn|umap-learn|hdbscan|numba|pynndescent\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "run_id": true,
                "model_id": true,
                "job": true,
                "instance": true,
                "Value": true
              },
              "renameByName": {
                "package": "Package",
                "version": "Installed Version"
              }
            }
          }
        ]
      },
      {
        "title": "",
        "type": "row",
        "gridPos": {"x": 0, "y": 13, "w": 24, "h": 1},
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Position Drift — Per-Feature Euclidean Distance",
        "description": "Euclidean distance between this run's feature positions and the reference dataset. Sorted descending — worst offenders first.",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 14, "w": 16, "h": 8},
        "targets": [
          {
            "expr": "topk(50, striatica_position_drift_per_feature{model_id=~\"$model_id\", run_id=\"$run_id\"})",
            "legendFormat": "Feature #{{feature_index}}"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "custom": {
              "drawStyle": "bars",
              "barAlignment": 0,
              "fillOpacity": 80
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.001, "color": "yellow"},
                {"value": 0.01, "color": "red"}
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          }
        }
      },
      {
        "title": "Drift Statistics",
        "description": "Summary stats for position drift across all features.",
        "type": "stat",
        "gridPos": {"x": 16, "y": 14, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "striatica_position_drift_max{model_id=~\"$model_id\", run_id=\"$run_id\"}",
            "legendFormat": "Max Drift"
          },
          {
            "expr": "striatica_position_drift_mean{model_id=~\"$model_id\", run_id=\"$run_id\"}",
            "legendFormat": "Mean Drift"
          },
          {
            "expr": "striatica_position_drift_p95{model_id=~\"$model_id\", run_id=\"$run_id\"}",
            "legendFormat": "P95 Drift"
          },
          {
            "expr": "striatica_position_drift_features_affected{model_id=~\"$model_id\", run_id=\"$run_id\"}",
            "legendFormat": "Features Affected"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "value",
          "graphMode": "none",
          "orientation": "vertical"
        },
        "fieldConfig": {
          "defaults": {
            "decimals": 6,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.001, "color": "yellow"},
                {"value": 0.01, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "title": "",
        "type": "row",
        "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1},
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Cross-Run Hash History",
        "description": "Output hashes across all runs. Identical hashes = reproducible. A change here means something shifted.",
        "type": "table",
        "gridPos": {"x": 0, "y": 23, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{model_id=~\"$model_id\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "__name__": true,
                "job": true,
                "instance": true,
                "Value": true
              },
              "indexByName": {
                "run_id": 0,
                "Time": 1,
                "model_id": 2,
                "platform_arch": 3,
                "docker_image_sha": 4,
                "output_sha256": 5,
                "pipeline_version": 6
              },
              "renameByName": {
                "run_id": "Run ID",
                "Time": "Timestamp",
                "model_id": "Model",
                "platform_arch": "Platform",
                "docker_image_sha": "Docker Image",
                "output_sha256": "Output SHA-256",
                "pipeline_version": "Pipeline Version"
              }
            }
          }
        ]
      },
      {
        "title": "",
        "type": "row",
        "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1},
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Docker Image History",
        "description": "Which Docker image produced each run. Different image = check deps.",
        "type": "stat",
        "gridPos": {"x": 0, "y": 32, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "{{docker_image_sha}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      },
      {
        "title": "Pipeline Version",
        "type": "stat",
        "gridPos": {"x": 8, "y": 32, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "v{{pipeline_version}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      },
      {
        "title": "Poetry Lockfile Hash",
        "description": "Even though Dockerfiles pip install now, track this for audit trail.",
        "type": "stat",
        "gridPos": {"x": 12, "y": 32, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "{{lockfile_sha256}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      },
      {
        "title": "Model ID",
        "type": "stat",
        "gridPos": {"x": 18, "y": 32, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "striatica_pipeline_run_info{run_id=\"$run_id\"}",
            "legendFormat": "{{model_id}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "none",
          "textMode": "name"
        }
      }
    ]
  },
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for striatica pipeline metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ]
}
